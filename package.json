{
  "name": "spectacular-lang",
  "version": "0.1.4",
  "description": "A layered specification language for defining software as a human- and AI-readable source of truth",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "specification",
    "spec",
    "software-design",
    "layered",
    "ai",
    "code-generation",
    "cross-platform"
  ],
  "bin": {
    "spc": "dist/cli.js"
  },
  "files": [
    "dist/",
    "language-spec.md",
    "AI.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run lint && npm run build",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src/",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.14.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "openai": "^4.85.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.0",
    "eslint": "^10.0.3",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-tsdoc": "^0.5.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18"
  }
}
